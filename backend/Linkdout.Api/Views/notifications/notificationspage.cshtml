@model List<Notification>
@{
    ViewData["Title"] = "الإشعارات";
    Layout = "_layout";
}

<style>
  .notif-page { max-width: 680px; margin: 0 auto; padding: 1.5rem 0; }
  .notif-page h2 { font-family: Amiri, serif; font-size: 1.6rem; color: var(--text); margin-bottom: 1.2rem; }
  .notif-item {
    display: flex; align-items: flex-start; gap: 0.8rem;
    padding: 1rem 1.2rem; border-radius: var(--radius); border: 1px solid var(--border-subtle);
    margin-bottom: 0.5rem; background: var(--bg-card); transition: var(--transition);
    cursor: pointer;
  }
  .notif-item:hover { border-color: var(--primary); box-shadow: var(--shadow-sm); }
  .notif-item .notif-icon {
    width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
    background: linear-gradient(135deg, rgba(124,58,237,0.12), rgba(6,182,212,0.08));
  }
  .notif-item .notif-body { flex: 1; min-width: 0; }
  .notif-item .notif-text { font-size: 0.88rem; color: var(--text); line-height: 1.5; }
  .notif-item .notif-time { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.25rem; }
  .notif-badge { font-size: 0.65rem; padding: 0.15rem 0.6rem; border-radius: 20px; background: var(--primary); color: #fff; }
  .notif-empty {
    text-align: center; padding: 4rem 1rem; color: var(--text-muted);
    font-family: Amiri, serif; font-size: 1.1rem;
  }
</style>

<div class="notif-page">
  <h2>🔔 الإشعارات</h2>

  @if (Model == null || Model.Count == 0)
  {
    <div class="notif-empty">لا توجد إشعارات حالياً — لما حد يتفاعل مع منشوراتك هتظهر هنا ✨</div>
  }
  else
  {
    @foreach (var n in Model)
    {
      var icon = "💬";
      if (n.Type?.Contains("like") == true) icon = "❤️";
      else if (n.Type?.Contains("connect") == true) icon = "🤝";
      else if (n.Type?.Contains("share") == true) icon = "📤";
      else if (n.Type?.Contains("comment") == true) icon = "💬";
      else if (n.Type?.Contains("mention") == true) icon = "📣";
      else if (n.Type?.Contains("badge") == true) icon = "🏆";

      var isNew = !n.IsRead;
      var link = n.Link ?? "#";

      <div class="notif-item @(isNew ? "" : "")" onclick="window.location.href='@link'" style="@(isNew ? "border-left: 3px solid var(--primary)" : "opacity:0.7")">
        <div class="notif-icon">@icon</div>
        <div class="notif-body">
          <div class="notif-text">@n.Body @if (isNew) { <span class="notif-badge">جديد</span> }</div>
          <div class="notif-time">@n.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</div>
        </div>
      </div>
    }
  }
</div>
