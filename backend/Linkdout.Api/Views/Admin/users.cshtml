@{
    Layout = "_Layout";
    ViewBag.Title = "إدارة المستخدمين";
    var users = ViewBag.Users as List<Linkdout.Api.DTOs.UserDto> ?? new();
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var page = (int)(ViewBag.Page ?? 1);
    var search = ViewBag.Search as string;
    var roleFilter = ViewBag.Role as string;
    var statusFilter = ViewBag.Status as string;
    var totalPages = (int)Math.Ceiling(totalCount / 20.0);
}
<style>
:root { --sidebar-w: 260px; }
.admin-layout { display: flex; min-height: calc(100vh - 60px); }
.admin-sidebar {
  width: var(--sidebar-w); min-width: var(--sidebar-w);
  background: var(--bg-card); border-left: 1px solid var(--border-subtle);
  padding: 1rem 0; position: sticky; top: 60px; height: calc(100vh - 60px); overflow-y: auto;
}
.admin-sidebar .logo { padding: 0.5rem 1.5rem 1.5rem; border-bottom: 1px solid var(--border-subtle); margin-bottom: 0.8rem; }
.admin-sidebar .logo h2 { font-family: Amiri, serif; font-size: 1.3rem; color: var(--primary); margin: 0; }
.admin-nav a { display: flex; align-items: center; gap: 0.7rem; padding: 0.7rem 1.5rem; color: var(--text-secondary); text-decoration: none; font-size: 0.88rem; transition: var(--transition); border-right: 3px solid transparent; }
.admin-nav a:hover, .admin-nav a.active { background: linear-gradient(90deg, rgba(124,58,237,0.08), transparent); color: var(--primary); border-right-color: var(--primary); }
.admin-nav a .icon { font-size: 1.1rem; width: 22px; text-align: center; }
.admin-main { flex: 1; padding: 1.5rem 2rem; overflow-x: hidden; }
.admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.2rem; }
.admin-header h1 { font-family: Amiri, serif; font-size: 1.6rem; color: var(--text); margin: 0; }

.chart-card { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius); padding: 1.2rem; }
.data-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.data-table th { text-align: right; padding: 0.7rem 0.8rem; background: var(--bg); color: var(--text-muted); font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid var(--border-subtle); }
.data-table td { padding: 0.7rem 0.8rem; border-bottom: 1px solid var(--border-subtle); color: var(--text-secondary); }
.data-table tr:hover td { background: rgba(124,58,237,0.03); }
.user-cell { display: flex; align-items: center; gap: 0.6rem; }
.user-avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--accent)); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 0.85rem; font-family: Amiri, serif; }
.badge-role { font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: 8px; font-weight: 600; }
.badge-role.admin { background: rgba(124,58,237,0.15); color: var(--primary); }
.badge-role.user { background: rgba(6,182,212,0.1); color: var(--accent); }
.badge-status { font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: 8px; }
.badge-status.active { background: rgba(16,185,129,0.1); color: var(--emerald); }
.badge-status.inactive { background: rgba(244,63,94,0.1); color: var(--rose); }
.btn-sm { padding: 0.3rem 0.6rem; font-size: 0.72rem; border-radius: 6px; cursor: pointer; border: 1px solid var(--border-subtle); background: transparent; color: var(--text-secondary); transition: var(--transition); }
.btn-sm:hover { border-color: var(--primary); color: var(--primary); }
.btn-sm.danger { color: var(--rose); border-color: rgba(244,63,94,0.2); }
.btn-sm.danger:hover { background: var(--rose); color: #fff; }
.filter-bar { display: flex; gap: 0.8rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: center; }
.filter-bar input, .filter-bar select { padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-subtle); background: var(--bg); color: var(--text); font-family: inherit; font-size: 0.85rem; }
.filter-bar input:focus, .filter-bar select:focus { border-color: var(--primary); outline: none; }
.filter-bar input { min-width: 250px; }
.pagination { display: flex; gap: 0.3rem; justify-content: center; margin-top: 1.5rem; }
.pagination a, .pagination span { padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; text-decoration: none; border: 1px solid var(--border-subtle); color: var(--text-secondary); transition: var(--transition); }
.pagination a:hover { border-color: var(--primary); color: var(--primary); }
.pagination .current { background: var(--primary); color: #fff; border-color: var(--primary); }
.toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--bg-card); border: 1px solid var(--border-accent); padding: 0.7rem 1.5rem; border-radius: 12px; box-shadow: var(--shadow-xl); font-size: 0.85rem; color: var(--text); z-index: 9999; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
.toast.show { opacity: 1; }
</style>

<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="logo"><h2>🦊 Linkdout</h2><span>لوحة تحكم الأدمن</span></div>
    <nav class="admin-nav">
      <a href="/Admin"><span class="icon">📊</span> الإحصائيات</a>
      <a href="/Admin/Users" class="active"><span class="icon">👥</span> المستخدمين</a>
      <a href="/Admin/Posts"><span class="icon">📝</span> المنشورات</a>
      <a href="/Admin/Analytics"><span class="icon">📈</span> التحليلات</a>
      <a href="/" style="margin-top:1rem;border-top:1px solid var(--border-subtle);padding-top:1rem"><span class="icon">🏠</span> العودة للمنصة</a>
    </nav>
  </aside>

  <main class="admin-main">
    <div class="admin-header"><h1>👥 إدارة المستخدمين</h1><span style="font-size:0.82rem;color:var(--text-muted)">@totalCount مستخدم</span></div>

    <form class="filter-bar" method="get" action="/Admin/Users">
      <input type="text" name="search" value="@search" placeholder="🔍 بحث بالاسم أو البريد...">
      <select name="role">
        <option value="">كل الأدوار</option>
        <option value="admin" selected="@(roleFilter=="admin")">أدمن</option>
        <option value="user" selected="@(roleFilter=="user")">مستخدم</option>
      </select>
      <select name="status">
        <option value="">كل الحالات</option>
        <option value="active" selected="@(statusFilter=="active")">نشط</option>
        <option value="inactive" selected="@(statusFilter=="inactive")">معطل</option>
      </select>
      <button type="submit" class="btn-sm" style="background:var(--primary);color:#fff;border:none;">تصفية</button>
    </form>

    <div class="chart-card">
      <table class="data-table">
        <thead><tr><th>المستخدم</th><th>البريد</th><th>XP</th><th>الدور</th><th>الحالة</th><th>التسجيل</th><th>إجراءات</th></tr></thead>
        <tbody>
        @foreach (var u in users)
        {
          <tr>
            <td><div class="user-cell"><div class="user-avatar">@(u.FullName?[0].ToString() ?? "?")</div><div><div style="font-weight:600">@u.FullName</div><div style="font-size:0.7rem;color:var(--text-muted)">@u.Headline</div></div></div></td>
            <td>@u.Email</td>
            <td style="color:var(--primary);font-weight:600">@u.XP</td>
            <td><span class="badge-role @u.Role">@(u.Role == "admin" ? "أدمن" : "مستخدم")</span></td>
            <td><span class="badge-status @(u.IsActive ? "active" : "inactive")">@(u.IsActive ? "نشط" : "معطل")</span></td>
            <td>@u.CreatedAt.ToString("yyyy/MM/dd")</td>
            <td>
              <button class="btn-sm" onclick="toggleActive(@u.Id,this)" title="@(u.IsActive ? "تعطيل" : "تفعيل")">@(u.IsActive ? "🚫 تعطيل" : "✅ تفعيل")</button>
              <button class="btn-sm" onclick="toggleAdmin(@u.Id,this)" title="@(u.Role=="admin"?"إلغاء صلاحية":"ترقية لأدمن")">@(u.Role == "admin" ? "⬇️" : "⬆️")</button>
              @if (u.Role != "admin") { <button class="btn-sm danger" onclick="deleteUser(@u.Id,this)">🗑️</button> }
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>

    @if (totalPages > 1)
    {
      <div class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
          var qs = $"page={i}";
          if (!string.IsNullOrEmpty(search)) qs += $"&search={Uri.EscapeDataString(search)}";
          if (!string.IsNullOrEmpty(roleFilter)) qs += $"&role={roleFilter}";
          if (!string.IsNullOrEmpty(statusFilter)) qs += $"&status={statusFilter}";
          if (i == page) { <span class="current">@i</span> }
          else { <a href="?@qs">@i</a> }
        }
      </div>
    }

    <div class="toast" id="toast"></div>
  </main>
</div>

<script>
function showToast(m){var t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(function(){t.classList.remove('show')},2500)}

function toggleActive(id,btn){
  fetch('/Admin/Users/ToggleActive/'+id,{method:'POST'}).then(r=>r.json()).then(d=>{
    if(d.ok){
      var row=btn.closest('tr');
      var badge=row.querySelector('.badge-status');
      if(d.isActive){badge.className='badge-status active';badge.textContent='نشط';btn.innerHTML='🚫 تعطيل'}
      else{badge.className='badge-status inactive';badge.textContent='معطل';btn.innerHTML='✅ تفعيل'}
      showToast(d.isActive?'تم التفعيل ✓':'تم التعطيل');
    }else{showToast(d.error)}
  });
}

function toggleAdmin(id,btn){
  fetch('/Admin/Users/MakeAdmin/'+id,{method:'POST'}).then(r=>r.json()).then(d=>{
    if(d.ok){
      var row=btn.closest('tr');
      var badge=row.querySelector('.badge-role');
      if(d.role=='admin'){badge.className='badge-role admin';badge.textContent='أدمن';btn.innerHTML='⬇️'}
      else{badge.className='badge-role user';badge.textContent='مستخدم';btn.innerHTML='⬆️'}
      showToast(d.role=='admin'?'تمت الترقية ✓':'تم إلغاء الصلاحية');
    }else{showToast(d.error)}
  });
}

function deleteUser(id,btn){
  if(!confirm('هل أنت متأكد من حذف هذا المستخدم؟ لا يمكن التراجع!'))return;
  fetch('/Admin/Users/'+id,{method:'DELETE'}).then(r=>r.json()).then(d=>{
    if(d.ok){btn.closest('tr').remove();showToast('تم الحذف ✓')}
    else{showToast(d.error)}
  });
}
</script>
