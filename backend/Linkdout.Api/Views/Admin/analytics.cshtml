@{
    Layout = "_Layout";
    ViewBag.Title = "التحليلات";
}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root { --sidebar-w: 260px; }
.admin-layout { display: flex; min-height: calc(100vh - 60px); }
.admin-sidebar { width: var(--sidebar-w); min-width: var(--sidebar-w); background: var(--bg-card); border-left: 1px solid var(--border-subtle); padding: 1rem 0; position: sticky; top: 60px; height: calc(100vh - 60px); overflow-y: auto; }
.admin-sidebar .logo { padding: 0.5rem 1.5rem 1.5rem; border-bottom: 1px solid var(--border-subtle); margin-bottom: 0.8rem; }
.admin-sidebar .logo h2 { font-family: Amiri, serif; font-size: 1.3rem; color: var(--primary); margin: 0; }
.admin-nav a { display: flex; align-items: center; gap: 0.7rem; padding: 0.7rem 1.5rem; color: var(--text-secondary); text-decoration: none; font-size: 0.88rem; transition: var(--transition); border-right: 3px solid transparent; }
.admin-nav a:hover, .admin-nav a.active { background: linear-gradient(90deg, rgba(124,58,237,0.08), transparent); color: var(--primary); border-right-color: var(--primary); }
.admin-nav a .icon { font-size: 1.1rem; width: 22px; text-align: center; }
.admin-main { flex: 1; padding: 1.5rem 2rem; overflow-x: hidden; }
.admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
.admin-header h1 { font-family: Amiri, serif; font-size: 1.6rem; color: var(--text); margin: 0; }
.chart-card { background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius); padding: 1.2rem; }
.chart-card h3 { font-family: Amiri, serif; font-size: 1.1rem; margin: 0 0 1rem; color: var(--text); }
.analytics-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
.analytics-grid.full { grid-template-columns: 1fr; }
.analytics-grid.three { grid-template-columns: 2fr 1fr; }
@@media (max-width: 1000px) { .analytics-grid, .analytics-grid.three { grid-template-columns: 1fr; } }
</style>

<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="logo"><h2>🦊 Linkdout</h2><span>لوحة تحكم الأدمن</span></div>
    <nav class="admin-nav">
      <a href="/Admin"><span class="icon">📊</span> الإحصائيات</a>
      <a href="/Admin/Users"><span class="icon">👥</span> المستخدمين</a>
      <a href="/Admin/Posts"><span class="icon">📝</span> المنشورات</a>
      <a href="/Admin/Analytics" class="active"><span class="icon">📈</span> التحليلات</a>
      <a href="/" style="margin-top:1rem;border-top:1px solid var(--border-subtle);padding-top:1rem"><span class="icon">🏠</span> العودة للمنصة</a>
    </nav>
  </aside>

  <main class="admin-main">
    <div class="admin-header"><h1>📈 التحليلات المتقدمة</h1></div>

    <!-- Row 1: Growth + Posts -->
    <div class="analytics-grid">
      <div class="chart-card"><h3>📈 نمو المستخدمين — آخر 30 يوم</h3><canvas id="growthChart" style="max-height:280px"></canvas></div>
      <div class="chart-card"><h3>📊 المنشورات اليومية — آخر 14 يوم</h3><canvas id="postsChart" style="max-height:280px"></canvas></div>
    </div>

    <!-- Row 2: XP + Engagement -->
    <div class="analytics-grid three">
      <div class="chart-card"><h3>⚡ توزيع نقاط الخبرة (XP)</h3><canvas id="xpDistChart" style="max-height:280px"></canvas></div>
      <div class="chart-card"><h3>💬 التفاعل — إعجابات / تعليقات</h3><canvas id="engagementChart" style="max-height:280px"></canvas></div>
    </div>

    <!-- Row 3: Top Users -->
    <div class="analytics-grid full">
      <div class="chart-card"><h3>🏆 أكثر 10 مستخدمين من حيث XP</h3><canvas id="topUsersChart" style="max-height:300px"></canvas></div>
    </div>
  </main>
</div>

<script>
Chart.defaults.font.family='Inter, Amiri, sans-serif';
Chart.defaults.color='#94a3b8';

fetch('/api/admin/charts').then(r=>r.json()).then(d=>{
  // Growth chart
  new Chart(document.getElementById('growthChart'),{
    type:'line',
    data:{labels:d.growth.labels,datasets:[{data:d.growth.data,borderColor:'#7C3AED',backgroundColor:'rgba(124,58,237,0.1)',borderWidth:2,fill:true,tension:0.3,pointRadius:0,pointHitRadius:10}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{grid:{color:'rgba(148,163,184,0.1)'}}}}
  });

  // Posts chart
  new Chart(document.getElementById('postsChart'),{
    type:'bar',
    data:{labels:d.posts.labels,datasets:[{data:d.posts.data,backgroundColor:'#06B6D4',borderRadius:6}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{grid:{color:'rgba(148,163,184,0.1)'}}}}
  });

  // XP Distribution
  new Chart(document.getElementById('xpDistChart'),{
    type:'doughnut',
    data:{labels:d.xp.labels,datasets:[{data:d.xp.data,backgroundColor:['#7C3AED','#8B5CF6','#06B6D4','#F59E0B','#F43F5E'],borderWidth:0}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{padding:12,usePointStyle:true,font:{size:11}}}}}
  });

  // Engagement
  new Chart(document.getElementById('engagementChart'),{
    type:'polarArea',
    data:{labels:d.engagement.labels,datasets:[{data:d.engagement.data,backgroundColor:['rgba(244,63,94,0.6)','rgba(6,182,212,0.6)','rgba(124,58,237,0.6)'],borderColor:['#F43F5E','#06B6D4','#7C3AED'],borderWidth:1}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{padding:12}}}}
  });

  // Top Users
  new Chart(document.getElementById('topUsersChart'),{
    type:'bar',
    data:{labels:d.topUsers.labels,datasets:[{data:d.topUsers.data,backgroundColor:['#7C3AED','#8B5CF6','#A78BFA','#7C3AEDcc','#8B5CF6cc','#06B6D4','#06B6D4aa','#10B981','#10B981aa','#F59E0B'],borderRadius:6}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},indexAxis:'y',scales:{x:{grid:{color:'rgba(148,163,184,0.1)'}},y:{grid:{display:false}}}}
  });
});
</script>
