@{
    var circles = ViewBag.Circles as IEnumerable<dynamic>;
    var total = ViewBag.TotalConnections as int? ?? 0;
    var circleNames = new Dictionary<string, string> { 
        ["close"] = "الدائرة القريبة", ["learning"] = "دائرة التعلم", ["professional"] = "الدائرة المهنية" 
    };
    var circleDescs = new Dictionary<string, string> { 
        ["close"] = "زمايلك المقربين والناس اللي بتثق فيهم", 
        ["learning"] = "ناس بتتعلم معاهم — كورسات ومشاريع تعليمية", 
        ["professional"] = "علاقاتك المهنية — زمايل شغل وناس من مجالك" 
    };
    var circleColors = new Dictionary<string, string> {
        ["close"] = "#7C3AED", ["learning"] = "#06B6D4", ["professional"] = "#1E1B4B"
    };
    var circleBorders = new Dictionary<string, string> {
        ["close"] = "var(--terracotta)", ["learning"] = "var(--gold)", ["professional"] = "var(--navy)"
    };
    
    // Build stats
    var closeCount = 0; var learnCount = 0; var proCount = 0; var otherCount = 0;
    var allMembers = new List<(string name, string circle)>();
    if (circles != null) {
        foreach (var c in circles) {
            var circleName = (string)c.Circle;
            var members = (IEnumerable<dynamic>)c.Connections;
            var count = members.Count();
            if (circleName == "close") closeCount = count;
            else if (circleName == "learning") learnCount = count;
            else if (circleName == "professional") proCount = count;
            else otherCount += count;
            foreach (var m in members) {
                allMembers.Add(((string)m.User.FullName, circleName));
            }
        }
    }
    var maxCount = Math.Max(1, Math.Max(closeCount, Math.Max(learnCount, Math.Max(proCount, otherCount))));
}
<div class="app-layout" style="grid-template-columns:1fr 340px">
<main>
  <h1 class="page-title animate-in">دوائرك</h1>
  <p class="page-subtitle animate-in" style="animation-delay:0.05s">علاقاتك مقسمة لدوائر ذكية — مش مجرد قائمة رقمية</p>

  @if (circles == null || allMembers.Count == 0)
  {
    <div class="empty-state animate-in">
      <div class="empty-state-icon">⭕</div>
      <h3>لا توجد علاقات بعد</h3>
      <p>ابدأ بإضافة أشخاص إلى شبكتك المهنية — ابحث عن زمايلك وأضفهم لدوائرك</p>
      <a href="/Search" class="btn btn-primary ripple" style="margin-top:1rem">🔍 ابحث عن أشخاص</a>
    </div>
  }
  else
  {
    <!-- Visualization -->
    <div class="card animate-in" style="margin-bottom:1.5rem">
      <div class="card-header"><h3>📊 توزيع العلاقات</h3><span style="font-size:0.75rem;color:var(--text-muted)">@total علاقة</span></div>
      <div style="display:flex;gap:1.5rem;align-items:flex-end;height:180px;padding:0.5rem 0">
        @foreach (var kv in new[] { ("close", closeCount, "القريبة", "#7C3AED"), ("learning", learnCount, "التعلم", "#06B6D4"), ("professional", proCount, "المهنية", "#1E1B4B") })
        {
          var h = (int)(140.0 * kv.Item2 / maxCount);
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;gap:0.5rem">
            <div style="font-family:Amiri,serif;font-weight:700;font-size:1.1rem">@kv.Item2</div>
            <div style="width:100%;max-width:80px;height:@(h)px;background:@kv.Item4;border-radius:12px 12px 0 0;transition:height 0.5s ease;min-height:4px;position:relative">
              @if (kv.Item2 == 0) { <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:0.7rem;color:rgba(255,255,255,0.5)">—</div> }
            </div>
            <div style="font-size:0.7rem;color:var(--text-secondary);text-align:center">@kv.Item3</div>
          </div>
        }
      </div>
    </div>

    <!-- Circle Cards -->
    @if (circles != null)
    {
      foreach (var circle in circles)
      {
        var circleName = (string)circle.Circle;
        var members = (IEnumerable<dynamic>)circle.Connections;
        var count = members.Count();
        var displayName = circleNames.ContainsKey(circleName) ? circleNames[circleName] : circleName + " دائرة";
        var desc = circleDescs.ContainsKey(circleName) ? circleDescs[circleName] : "علاقات مهنية";
        var borderColor = circleBorders.ContainsKey(circleName) ? circleBorders[circleName] : "var(--terracotta)";
        var dotClass = circleName == "close" ? "close" : circleName == "learning" ? "learn" : "professional";
        var barPercent = (int)(100.0 * count / maxCount);
        
        <div class="card animate-in" style="border-right:4px solid @borderColor;margin-bottom:0.8rem">
          <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:0.5rem">
            <div class="circle-dot @dotClass" style="width:14px;height:14px"></div>
            <h3 style="font-size:1.1rem;flex:1">@displayName</h3>
            <span style="font-family:Amiri,serif;font-weight:700;font-size:1.1rem;color:@borderColor">@count</span>
            <span style="font-size:0.75rem;color:var(--text-muted)">@(count == 1 ? "شخص" : count <= 10 ? "أشخاص" : "شخص")</span>
          </div>
          <div style="height:4px;background:var(--bg);border-radius:2px;margin-bottom:0.6rem">
            <div style="height:100%;width:@(barPercent)%;background:@borderColor;border-radius:2px;transition:width 0.5s ease"></div>
          </div>
          <p style="color:var(--text-secondary);font-size:0.8rem;margin-bottom:0.6rem">@desc</p>
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap">
            @foreach (var m in members)
            {
              <a href="/Profile/@m.User.Id" class="skill-tag" style="cursor:pointer;font-size:0.75rem;padding:0.3rem 0.7rem">@m.User.FullName</a>
            }
          </div>
        </div>
      }
    }
  }
</main>

<aside class="sidebar-right">
  <!-- Summary Card -->
  <div class="card">
    <div class="card-header"><h3>💡 ملخص سريع</h3></div>
    <div style="font-size:0.85rem;color:var(--text-secondary);line-height:2.2">
      <div style="display:flex;justify-content:space-between"><span><span style="color:#7C3AED">●</span> الدائرة القريبة</span><span style="font-family:Amiri,serif;font-weight:700">@closeCount</span></div>
      <div style="display:flex;justify-content:space-between"><span><span style="color:#06B6D4">●</span> دائرة التعلم</span><span style="font-family:Amiri,serif;font-weight:700">@learnCount</span></div>
      <div style="display:flex;justify-content:space-between"><span><span style="color:#1E1B4B">●</span> الدائرة المهنية</span><span style="font-family:Amiri,serif;font-weight:700">@proCount</span></div>
      @if (otherCount > 0)
      {
        <div style="display:flex;justify-content:space-between"><span><span style="color:var(--text-muted)">●</span> بدون دائرة</span><span style="font-family:Amiri,serif;font-weight:700">@otherCount</span></div>
      }
      <div style="border-top:1px solid var(--terracotta-bg);margin-top:0.4rem;padding-top:0.4rem;display:flex;justify-content:space-between;font-weight:600">
        <span>الإجمالي</span><span style="font-family:Amiri,serif;font-size:1.1rem;color:var(--terracotta)">@total علاقة</span>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="card">
    <div class="card-header"><h3>⚡ إجراءات سريعة</h3></div>
    <a href="/Search" class="btn btn-outline" style="width:100%;margin-bottom:0.5rem;justify-content:center">🔍 ابحث عن أشخاص جدد</a>
    <a href="/Connections" class="btn btn-outline" style="width:100%;justify-content:center">📋 إدارة الطلبات</a>
  </div>

  <!-- Tips -->
  <div class="card" style="background:var(--terracotta-bg);border:1px solid rgba(124,58,237,0.1)">
    <p style="font-size:0.8rem;color:var(--text-secondary);line-height:1.7">
      💡 <b>نصيحة:</b> قسم علاقاتك لدوائر — الدائرة القريبة لأقرب الناس ليك، دائرة التعلم لزمايل الدراسة، والدائرة المهنية لعلاقات الشغل.
    </p>
  </div>
</aside>
</div>
