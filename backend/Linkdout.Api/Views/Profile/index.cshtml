@{
    var profile = ViewBag.Profile as Linkdout.Api.DTOs.UserDto;
    var isOwn = ViewBag.IsOwnProfile as bool? == true;
    var statusText = profile?.Status switch { "open" => "🔥 جاهز للتحدي", "growing" => "🌱 في مرحلة نمو", "available" => "🤝 متاح للتعاون", "learning" => "🧘 في رحلة تعلم", _ => "🔥 جاهز للتحدي" };
    var userLevel = profile?.Level ?? 1;
    var levelTitle = userLevel <= 1 ? "🌱 مبتدئ" : userLevel <= 3 ? "🌿 متعلم" : userLevel <= 6 ? "🌳 محترف" : userLevel <= 10 ? "⭐ خبير" : userLevel <= 15 ? "👑 قائد" : "🏆 أسطورة";
}

<div class="profile-page">
  <!-- COVER -->
  <div class="profile-cover">
    <div class="profile-cover-gradient"></div>
    @if (isOwn)
    {
      <a href="/Profile/Edit" class="profile-edit-btn" title="تعديل الملف">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        تعديل الملف
      </a>
    }
  </div>

  <!-- PROFILE CARD -->
  <div class="profile-main-card">
    <div class="profile-avatar-lg">@(profile?.FullName?[0].ToString() ?? "?")</div>
    <div class="profile-info">
      <div class="profile-name-row">
        <h1>@profile?.FullName</h1>
        <span class="status-badge @(profile?.Status=="learning"?"learning":"open")">@statusText</span>
      </div>
      <p class="profile-headline">@profile?.Headline</p>
      <div class="profile-meta">
        @if (!string.IsNullOrEmpty(profile?.Location)) { <span>📍 @profile.Location</span> }
        @if (!string.IsNullOrEmpty(profile?.Website)) { <span>🔗 <a href="@profile.Website" target="_blank">@profile.Website</a></span> }
        <span>📅 انضم @profile?.CreatedAt.ToString("yyyy/MM")</span>
      </div>

      <!-- XP BAR -->
      <div class="profile-xp-section">
        @{
          var nextXp = userLevel <= 1 ? 100 : userLevel <= 3 ? 250 : userLevel <= 6 ? 500 : userLevel <= 10 ? 1000 : userLevel <= 15 ? 2500 : 5000;
          var xpPercent = Math.Min(100, (int)(100.0 * (profile?.XP ?? 0) / nextXp));
        }
        <div class="xp-header">
          <span class="xp-level">
            <span class="xp-level-icon">@(userLevel switch { <=1 => "🌱", <=3 => "🌿", <=6 => "🌳", <=10 => "⭐", <=15 => "👑", _ => "🏆" })</span>
            @levelTitle · المستوى @userLevel
          </span>
          <span class="xp-count">⚡ @(profile?.XP ?? 0) / @nextXp XP</span>
        </div>
        <div class="xp-bar-wrap"><div class="xp-bar-fill" style="width:@xpPercent%"></div></div>
      </div>
    </div>

    <!-- STATS -->
    <div class="profile-stats-row">
      <div class="pstat"><div class="pstat-num">@(profile?.ConnectionCount ?? 0)</div><div class="pstat-lbl">علاقة</div></div>
      <div class="pstat"><div class="pstat-num">@(profile?.Experiences?.Count ?? 0)</div><div class="pstat-lbl">خبرة</div></div>
      <div class="pstat"><div class="pstat-num">@(profile?.ProfileViews ?? 0)</div><div class="pstat-lbl">مشاهدة</div></div>
      <div class="pstat"><div class="pstat-num">@(profile?.XP ?? 0)</div><div class="pstat-lbl">XP</div></div>
    </div>

    @if (profile?.Badges?.Count > 0)
    {
      <div class="profile-badges-row">
        @foreach (var b in profile.Badges) { <span class="badge-chip">@b</span> }
      </div>
    }
  </div>

  <!-- CONTENT GRID -->
  <div class="profile-grid">
    <div class="profile-main-col">
      <!-- BIO -->
      @if (!string.IsNullOrEmpty(profile?.Bio))
      {
        <div class="profile-section scroll-reveal">
          <h3 class="section-title">📝 نبذة عني</h3>
          <p class="bio-text">@profile.Bio</p>
        </div>
      }

      <!-- SKILLS -->
      <div class="profile-section scroll-reveal">
        <h3 class="section-title">🛠️ المهارات</h3>
        @if (profile?.Skills?.Count > 0)
        {
          <div class="skills-cloud">
            @foreach (var s in profile.Skills) { <span class="skill-chip">@s</span> }
          </div>
        }
        else { <div class="empty-mini">لم يتم إضافة مهارات بعد</div> }
      </div>

      <!-- EXPERIENCES -->
      <div class="profile-section scroll-reveal">
        <h3 class="section-title">💼 الخبرات</h3>
        @if (profile?.Experiences?.Count > 0)
        {
          <div class="timeline">
            @foreach (var e in profile.Experiences)
            {
              <div class="timeline-item">
                <div class="timeline-dot @(e.IsCurrent ? "current" : "")">@(e.Type == "volunteer" ? "🤝" : e.Type == "education" ? "🎓" : "💼")</div>
                <div class="timeline-content">
                  <div class="timeline-title">@e.Title</div>
                  <div class="timeline-subtitle">@e.Company</div>
                  <div class="timeline-date">@(e.IsCurrent ? "حتى الآن" : e.EndDate?.ToString("yyyy/MM") ?? "") · @(e.StartDate?.ToString("yyyy/MM") ?? "")</div>
                  @if (!string.IsNullOrEmpty(e.Description)) { <div class="timeline-desc">@e.Description</div> }
                </div>
              </div>
            }
          </div>
        }
        else { <div class="empty-mini">لم يتم إضافة خبرات بعد</div> }
      </div>
    </div>

    <!-- SIDEBAR -->
    <div class="profile-side-col">
      @{
        var score = 20;
        if (!string.IsNullOrEmpty(profile?.Bio)) score += 15;
        if (!string.IsNullOrEmpty(profile?.Headline)) score += 10;
        if (!string.IsNullOrEmpty(profile?.Location)) score += 10;
        if (profile?.Skills?.Count > 0) score += 15;
        if (profile?.Experiences?.Count > 0) score += 15;
      }
      <div class="profile-side-card scroll-reveal">
        <h4>📊 قوة الملف</h4>
        <div class="strength-ring" style="--strength:@score%">
          <span class="strength-val">@score%</span>
        </div>
        <p class="strength-label">@(score < 40 ? "مبتدئ — أكمل ملفك" : score < 70 ? "متوسط — في تقدم" : "مكتمل — ملف قوي")</p>
        <div class="strength-tips">
          @if (string.IsNullOrEmpty(profile?.Bio)) { <div class="tip-item">✏️ أضف نبذة عنك</div> }
          @if (string.IsNullOrEmpty(profile?.Headline)) { <div class="tip-item">💡 أضف عنوان وظيفي</div> }
          @if (profile?.Skills?.Count == 0) { <div class="tip-item">🛠️ أضف مهاراتك</div> }
          @if (profile?.Experiences?.Count == 0) { <div class="tip-item">💼 أضف خبراتك</div> }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.profile-page{max-width:900px;margin:0 auto;padding-bottom:3rem}
.profile-cover{height:200px;border-radius:0 0 var(--radius) var(--radius);background:linear-gradient(135deg,var(--primary),var(--accent),#1E1B4B);position:relative;overflow:hidden}
.profile-cover-gradient{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 30% 80%,rgba(255,255,255,0.08) 0%,transparent 60%),radial-gradient(circle at 80% 20%,rgba(255,255,255,0.04) 0%,transparent 40%)}
.profile-edit-btn{position:absolute;top:1rem;left:1rem;display:flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;border-radius:50px;background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);color:#fff;text-decoration:none;font-size:0.82rem;font-weight:500;transition:var(--transition);border:1px solid rgba(255,255,255,0.1)}
.profile-edit-btn:hover{background:rgba(255,255,255,0.25);transform:translateY(-2px)}

.profile-main-card{background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:var(--radius);padding:2rem;margin-top:-60px;position:relative;z-index:2;margin-bottom:1.5rem;box-shadow:var(--shadow-lg)}
.profile-avatar-lg{width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;color:#fff;font-family:Amiri,serif;font-size:2.8rem;font-weight:700;margin-top:-110px;margin-bottom:1rem;box-shadow:0 0 0 4px var(--bg),0 0 0 6px rgba(124,58,237,0.15);position:relative}
.profile-name-row{display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;margin-bottom:0.4rem}
.profile-name-row h1{font-family:Amiri,serif;font-size:1.8rem;margin:0;color:var(--text)}
.profile-headline{font-size:0.95rem;color:var(--text-secondary);margin-bottom:0.5rem}
.profile-meta{display:flex;gap:1.2rem;flex-wrap:wrap;font-size:0.8rem;color:var(--text-muted);margin-bottom:1rem}
.profile-meta a{color:var(--primary);text-decoration:none}

.profile-xp-section{margin-bottom:1rem}
.xp-header{display:flex;justify-content:space-between;align-items:center;font-size:0.82rem;margin-bottom:0.5rem}
.xp-level{display:flex;align-items:center;gap:0.3rem;font-weight:600;color:var(--text)}
.xp-level-icon{font-size:1.1rem}
.xp-count{color:var(--primary);font-weight:600}
.xp-bar-wrap{height:8px;background:var(--bg);border-radius:4px;overflow:hidden}
.xp-bar-fill{height:100%;background:linear-gradient(90deg,var(--primary),var(--accent));border-radius:4px;transition:width 1s ease;box-shadow:0 0 8px rgba(124,58,237,0.3)}

.profile-stats-row{display:flex;gap:0;border-top:1px solid var(--border-subtle);padding-top:1rem}
.pstat{flex:1;text-align:center}
.pstat-num{font-family:Amiri,serif;font-size:1.4rem;font-weight:700;color:var(--text)}
.pstat-lbl{font-size:0.72rem;color:var(--text-muted);margin-top:0.1rem}

.profile-badges-row{display:flex;gap:0.4rem;flex-wrap:wrap;padding-top:0.8rem;border-top:1px solid var(--border-subtle);margin-top:0.8rem}
.badge-chip{padding:0.25rem 0.7rem;border-radius:20px;font-size:0.72rem;background:linear-gradient(135deg,rgba(245,158,11,0.12),rgba(124,58,237,0.08));color:var(--amber);border:1px solid rgba(245,158,11,0.15);font-weight:500}

.profile-grid{display:grid;grid-template-columns:1fr 280px;gap:1.5rem}
.profile-main-col{display:flex;flex-direction:column;gap:1.5rem}
.profile-side-col{display:flex;flex-direction:column;gap:1.5rem}
.profile-section{background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:var(--radius);padding:1.5rem}
.section-title{font-family:Amiri,serif;font-size:1.15rem;margin:0 0 1rem;color:var(--text);display:flex;align-items:center;gap:0.4rem;padding-bottom:0.7rem;border-bottom:1px solid var(--border-subtle)}
.bio-text{line-height:2.1;color:var(--text-secondary);font-size:0.9rem}

.skills-cloud{display:flex;flex-wrap:wrap;gap:0.5rem}
.skill-chip{padding:0.4rem 0.9rem;border-radius:12px;font-size:0.82rem;font-weight:500;background:linear-gradient(135deg,rgba(124,58,237,0.08),rgba(6,182,212,0.05));color:var(--primary);border:1px solid rgba(124,58,237,0.1);transition:all 0.25s}
.skill-chip:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(124,58,237,0.12);border-color:var(--primary)}

.timeline{display:flex;flex-direction:column;gap:0;position:relative}
.timeline::before{content:'';position:absolute;right:19px;top:0;bottom:0;width:2px;background:var(--border-subtle)}
.timeline-item{display:flex;gap:1rem;padding:0.8rem 0;position:relative}
.timeline-dot{width:40px;height:40px;border-radius:50%;background:var(--bg);border:2px solid var(--border-subtle);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;z-index:1}
.timeline-dot.current{border-color:var(--emerald);background:rgba(16,185,129,0.06)}
.timeline-content{flex:1;min-width:0}
.timeline-title{font-weight:600;font-size:0.9rem;color:var(--text)}
.timeline-subtitle{font-size:0.82rem;color:var(--text-secondary);margin-top:0.15rem}
.timeline-date{font-size:0.7rem;color:var(--text-muted);margin-top:0.2rem}
.timeline-desc{font-size:0.8rem;color:var(--text-secondary);margin-top:0.4rem;line-height:1.8}

.profile-side-card{background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:var(--radius);padding:1.5rem;text-align:center}
.profile-side-card h4{font-family:Amiri,serif;font-size:1rem;margin:0 0 1rem;color:var(--text)}
.strength-ring{width:100px;height:100px;border-radius:50%;margin:0 auto 0.8rem;background:conic-gradient(var(--primary) var(--strength),var(--border-subtle) var(--strength));display:flex;align-items:center;justify-content:center;position:relative}
.strength-ring::before{content:'';position:absolute;width:80px;height:80px;border-radius:50%;background:var(--bg-card)}
.strength-val{position:relative;z-index:1;font-family:Amiri,serif;font-size:1.5rem;font-weight:700;color:var(--primary)}
.strength-label{font-size:0.78rem;color:var(--text-muted);margin-bottom:0.8rem}
.strength-tips{text-align:right;display:flex;flex-direction:column;gap:0.4rem}
.tip-item{font-size:0.75rem;color:var(--amber);background:rgba(245,158,11,0.06);padding:0.4rem 0.7rem;border-radius:8px;border:1px solid rgba(245,158,11,0.1)}
.empty-mini{text-align:center;padding:1.5rem;color:var(--text-muted);font-size:0.85rem}

@@media (max-width:768px){
  .profile-grid{grid-template-columns:1fr}
  .profile-meta{flex-direction:column;gap:0.3rem}
}
</style>
