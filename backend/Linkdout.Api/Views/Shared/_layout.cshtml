@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = isAuthenticated ? User.FindFirstValue(ClaimTypes.Name) : "";
    var userId = isAuthenticated ? User.FindFirstValue(ClaimTypes.NameIdentifier) : "0";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#7C3AED">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="manifest" href="/manifest.json">
<title>Linkdout — شبكتك المهنية</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=Noto+Naskh+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/linkdout.css">
</head>
<body>

<!-- Navbar -->
@if (isAuthenticated)
{
<nav class="navbar">
  <div style="display:flex;align-items:center;gap:0.8rem">
    <button class="hamburger" onclick="toggleMobileMenu()" aria-label="قائمة">
      <span></span><span></span><span></span>
    </button>
    <a class="nav-logo" href="/">Linkdout<span class="dot"></span></a>
  </div>
  <div class="nav-links">
    <form action="/Search" method="get" style="position:relative;margin:0 0.5rem">
      <input name="q" placeholder="بحث سريع..." style="width:180px;padding:0.4rem 0.7rem;border-radius:24px;border:1.5px solid rgba(124,58,237,0.1);font-family:inherit;font-size:0.75rem;background:var(--bg);color:var(--text);transition:var(--transition)" onfocus="this.style.width='280px';this.style.borderColor='var(--primary)';this.style.boxShadow='0 0 0 3px var(--primary-bg)'" onblur="this.style.width='180px';this.style.borderColor='rgba(124,58,237,0.1)';this.style.boxShadow='none'">
    </form>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" href="/">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>الرئيسية</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Bookmarks" ? "active" : "")" href="/Bookmarks">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
      <span>محفوظات</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Circles" ? "active" : "")" href="/Circles">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
      <span>الدوائر</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Groups" ? "active" : "")" href="/Groups">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span>المجموعات</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Companies" ? "active" : "")" href="/Companies">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
      <span>شركات</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Opportunities" ? "active" : "")" href="/Opportunities">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7h-7l-2-3H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2z"/></svg>
      <span>الفرص</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Search" ? "active" : "")" href="/Search">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <span>بحث</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Notifications" ? "active" : "") notif-dot" href="/Connections" id="notif-link">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <span>طلبات</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Gamification" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" href="/Leaderboard">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 6 9 6 9z"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 18 9 18 9z"/><path d="M4 22h16"/><path d="M10 22V2h4v20"/></svg>
      <span>المتصدرين</span>
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Gamification" && ViewContext.RouteData.Values["Action"]?.ToString() == "JobMatch" ? "active" : "")" href="/Jobs/Match">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      <span>مطابقة</span>
    </a>
    @if (User.Identity?.IsAuthenticated == true)
    {
      var adminCheck = Context.RequestServices.GetRequiredService<Linkdout.Api.Data.AppDbContext>()
          .Users.FirstOrDefault(u => u.Email == User.FindFirst(System.Security.Claims.ClaimTypes.Email).Value);
      if (adminCheck != null && adminCheck.Role == "admin")
      {
        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")" href="/Admin" style="color:var(--primary);font-weight:600">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span>الإدارة</span>
        </a>
      }
    }
    <a class="nav-link" href="/Account/Logout">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      <span>خروج</span>
    </a>
  </div>
  <a href="/Profile" style="display:flex;align-items:center;gap:0.5rem">
    <button class="nav-icon-btn notif-bell" onclick="toggleNotifDropdown(event)" title="الإشعارات" style="position:relative;background:none;border:none;cursor:pointer;font-size:1.2rem;padding:0.4rem;border-radius:50%;transition:var(--transition);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text-secondary)">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    <span id="notif-badge" style="position:absolute;top:-2px;right:-2px;background:var(--energy);color:#fff;font-size:0.6rem;min-width:16px;height:16px;border-radius:8px;align-items:center;justify-content:center;padding:0 4px;font-weight:700;display:none">0</span>
  </button>
  <button class="theme-toggle" onclick="toggleTheme()" aria-label="تغيير المظهر" title="تغيير المظهر">🌙</button>
    <div style="width:36px;height:36px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-family:Amiri,serif">@(userName.Length > 0 ? userName[0].ToString() : "ك")</div>
  </a>
</nav>

<button class="fab" onclick="document.querySelector('.composer')?.click()" title="منشور جديد" aria-label="إنشاء منشور">
  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
</button>
}

@RenderBody()

@if (isAuthenticated) {
<footer style="margin-top:3rem;padding:2rem;text-align:center;border-top:1px solid rgba(192,122,75,0.06);position:relative;z-index:1">
  <div style="font-family:Amiri,serif;font-size:1.2rem;color:var(--terracotta);margin-bottom:0.3rem">Linkdout<span style="display:inline-block;width:7px;height:7px;background:var(--gold);border-radius:50%;margin-right:3px;box-shadow:0 0 8px rgba(224,176,80,0.5)"></span></div>
  <p style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.8rem">الشبكة المهنية المصرية | صنع بحب في مصر</p>
  <div style="display:flex;gap:1.5rem;justify-content:center;flex-wrap:wrap;font-size:0.72rem">
    <a href="/" style="color:var(--text-muted);transition:var(--transition)" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color=''">الرئيسية</a>
    <a href="/Leaderboard" style="color:var(--text-muted);transition:var(--transition)" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color=''">المتصدرين</a>
    <a href="/Jobs/Match" style="color:var(--text-muted);transition:var(--transition)" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color=''">مطابقة الوظائف</a>
    <a href="/Groups" style="color:var(--text-muted);transition:var(--transition)" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color=''">المجموعات</a>
    <a href="https://keroles-sala.me" target="_blank" style="color:var(--text-muted);transition:var(--transition)" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color=''">Portfolio</a>
  </div>
</footer>
}

<div class="toast" id="toast"></div>

<div class="share-modal-overlay" id="shareModalOverlay">
  <div class="share-modal">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
      <h3>مشاركة المنشور</h3>
      <button onclick="document.getElementById('shareModalOverlay').classList.remove('active')" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--text-muted)">&times;</button>
    </div>
    <div class="share-link"><input type="text" id="shareLinkInput" readonly><button class="btn btn-primary" onclick="copyShareLink()" style="font-size:0.8rem;padding:0.5rem 1rem">نسخ</button></div>
    <div class="share-actions">
      <button class="btn btn-outline" style="font-size:0.78rem" onclick="shareToWhatsApp()">💬 واتساب</button>
      <button class="btn btn-outline" style="font-size:0.78rem" onclick="shareToTwitter()">🐦 تويتر</button>
      <button class="btn btn-outline" style="font-size:0.78rem" onclick="copyShareLink()">📋 نسخ الرابط</button>
    </div>
  </div>
</div>

<div id="notif-dropdown" style="display:none;position:fixed;top:64px;left:2rem;width:360px;max-height:400px;overflow-y:auto;background:var(--bg-card);backdrop-filter:blur(20px);border:1px solid rgba(124,58,237,0.1);border-radius:var(--radius-lg);box-shadow:var(--shadow-xl);z-index:200;padding:1rem">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.8rem;padding-bottom:0.6rem;border-bottom:1px solid rgba(124,58,237,0.08)">
    <h3 style="font-size:0.95rem;font-family:Amiri,serif">🔔 الإشعارات</h3>
    <button onclick="document.getElementById('notif-dropdown').style.display='none'" style="background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text-muted)">&times;</button>
  </div>
  <div id="notif-list" style="display:flex;flex-direction:column;gap:0.4rem">
    <div class="spinner" style="margin:1rem auto"></div>
  </div>
  <a href="/Notifications" style="display:block;text-align:center;padding:0.6rem;margin-top:0.6rem;border-top:1px solid var(--border-subtle);color:var(--primary);font-size:0.82rem;text-decoration:none;font-weight:500" onmouseover="this.style.background='rgba(124,58,237,0.05)'" onmouseout="this.style.background='none'">عرض كل الإشعارات →</a>
</div>

<script>
// Dark mode
(function(){
  var saved=localStorage.getItem('linkdout-theme');
  if(saved==='dark'||(!saved&&window.matchMedia('(prefers-color-scheme:dark)').matches)){
    document.documentElement.setAttribute('data-theme','dark');
    var btn=document.querySelector('.theme-toggle');
    if(btn)btn.textContent='☀️';
  }
})();
function toggleTheme(){
  var isDark=document.documentElement.getAttribute('data-theme')==='dark';
  if(isDark){
    document.documentElement.removeAttribute('data-theme');
    localStorage.setItem('linkdout-theme','light');
    document.querySelector('.theme-toggle').textContent='🌙';
  }else{
    document.documentElement.setAttribute('data-theme','dark');
    localStorage.setItem('linkdout-theme','dark');
    document.querySelector('.theme-toggle').textContent='☀️';
  }
}
// Mobile menu
function toggleMobileMenu(){
  var nav=document.querySelector('.nav-links');
  var ham=document.querySelector('.hamburger');
  nav.classList.toggle('mobile-open');
  ham.classList.toggle('active');
}
// Close mobile menu on link click
document.querySelectorAll('.nav-link').forEach(function(l){
  l.addEventListener('click',function(){
    document.querySelector('.nav-links').classList.remove('mobile-open');
    document.querySelector('.hamburger').classList.remove('active');
  });
});

// Notification count + bell
fetch('/api/notifications/count').then(r=>r.json()).then(d=>{
  if(d.count>0){
    var bell=document.getElementById('notif-link');
    if(bell){bell.querySelector('span').textContent='طلبات ('+d.count+')';bell.style.color='var(--primary)';}
    var badge=document.getElementById('notif-badge');
    if(badge){badge.style.display='flex';badge.textContent=d.count;}
  }
});

// Notification dropdown
function toggleNotifDropdown(e){
  e.stopPropagation();
  var dd=document.getElementById('notif-dropdown');
  if(dd.style.display==='flex'){dd.style.display='none';return}
  dd.style.display='flex';
  fetch('/api/notifications').then(r=>r.json()).then(d=>{
    var list=document.getElementById('notif-list');
    if(d.notifications&&d.notifications.length>0){
      list.innerHTML=d.notifications.slice(0,8).map(function(n){
        var icon=n.type==='like'?'❤️':n.type==='comment'?'💬':'🤝';
        var link=n.type==='connection'?'/Connections':'/Profile/'+n.userId;
        return '<a href="'+link+'" style="display:flex;align-items:flex-start;gap:0.7rem;padding:0.6rem;border-radius:10px;transition:var(--transition);font-size:0.82rem;text-decoration:none;color:var(--text)" onmouseover="this.style.background=\'var(--bg)\'" onmouseout="this.style.background=\'transparent\'"><span style="font-size:1.2rem">'+icon+'</span><div style="flex:1"><div style="font-size:0.8rem">'+n.text+'</div><div style="font-size:0.65rem;color:var(--text-muted)">'+n.time+'</div></div></a>';
      }).join('');
    }else{list.innerHTML='<div style="text-align:center;padding:1rem;color:var(--text-muted);font-size:0.82rem">لا توجد إشعارات جديدة</div>'}
  });
}
document.addEventListener('click',function(e){
  var dd=document.getElementById('notif-dropdown');
  if(dd&&dd.style.display==='flex'&&!e.target.closest('#notif-dropdown')&&!e.target.closest('.notif-bell')){dd.style.display='none'}
});

function showToast(m){var t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(function(){t.classList.remove('show')},2500)}

// ===== POST ACTIONS (like, comment, share) =====
document.addEventListener('click',function(e){
  var btn=e.target.closest('.post-action');
  if(!btn)return;
  var action=btn.dataset.action;
  var postEl=btn.closest('.post, .card');
  var postId=postEl?postEl.dataset.postId:null;
  if(!postId&&action!=='share')return;

  // LIKE
  if(action==='like'){
    e.preventDefault();
    fetch('/api/interactions/like/'+postId,{method:'POST',headers:{'Content-Type':'application/json'}})
    .then(r=>r.json()).then(d=>{
      var svg=btn.querySelector('svg path');
      if(d.liked){btn.classList.add('liked');if(svg)svg.setAttribute('fill','currentColor')}
      else{btn.classList.remove('liked');if(svg)svg.setAttribute('fill','none')}
      var sp=btn.querySelector('span:last-child');if(sp)sp.textContent=d.likeCount;
    }).catch(function(){});
  }

  // COMMENT
  if(action==='comment'){
    e.preventDefault();
    var existing=postEl.querySelector('.comments-section');
    if(existing){existing.remove();return;}
    var sec=document.createElement('div');sec.className='comments-section';
    sec.style.cssText='padding:0.8rem 1.3rem;border-top:1px solid var(--border-subtle);max-height:320px;overflow-y:auto;background:var(--bg)';
    var inp=document.createElement('div');inp.style.cssText='display:flex;gap:0.5rem;margin-bottom:0.8rem';
    inp.innerHTML='<input type="text" placeholder="اكتب تعليقاً..." style="flex:1;padding:0.5rem 0.8rem;border-radius:10px;border:1.5px solid var(--border-subtle);font-family:inherit;font-size:0.85rem;background:var(--bg-card);color:var(--text)"><button style="padding:0.5rem 1rem;border-radius:10px;background:var(--primary);color:#fff;border:none;font-family:inherit;cursor:pointer;font-size:0.82rem;white-space:nowrap">أرسل</button>';
    sec.appendChild(inp);
    var list=document.createElement('div');sec.appendChild(list);
    postEl.appendChild(sec);
    fetch('/api/interactions/comments/'+postId).then(r=>r.json()).then(function(comments){
      (comments||[]).forEach(function(c){
        var d=document.createElement('div');d.style.cssText='padding:0.5rem 0;font-size:0.85rem;border-bottom:1px solid var(--border-subtle)';
        d.innerHTML='<b style=\"color:var(--primary)\">'+(c.authorName||c.author||'مستخدم')+'</b> <span style=\"color:var(--text-secondary);font-size:0.82rem\">'+c.body+'</span>';
        list.appendChild(d);
      });
    });
    inp.querySelector('button').addEventListener('click',function(){
      var val=inp.querySelector('input').value.trim();if(!val)return;
      fetch('/api/interactions/comment/'+postId,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({body:val})})
      .then(r=>r.json()).then(function(d){
        var el=document.createElement('div');el.style.cssText='padding:0.5rem 0;font-size:0.85rem';
        el.innerHTML='<b style=\"color:var(--primary)\">'+(d.author||'أنت')+'</b> <span style=\"color:var(--text-secondary);font-size:0.82rem\">'+d.body+'</span>';
        list.appendChild(el);inp.querySelector('input').value='';
        var sp=btn.querySelector('span:last-child');if(sp)sp.textContent=(parseInt(sp.textContent||0)+1);
      });
    });
  }

  // SHARE
  if(action==='share'){
    e.preventDefault();if(!postId)return;
    fetch('/api/interactions/share/'+postId,{method:'POST'}).then(r=>r.json()).then(function(d){
      showToast('تمت المشاركة!');
    }).catch(function(){});
  }
});

// ═══ POST COMPOSER with IMGBB UPLOAD ═══
var uploadedImages=[];var uploadingCount=0;
document.addEventListener('click',function(e){
  var comp=e.target.closest('.composer');
  if(!comp)return;
  if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.tagName==='BUTTON'||e.target.tagName==='LABEL')return;
  var existing=document.querySelector('.composer-modal');
  if(existing){existing.remove();uploadedImages=[];return;}
  uploadedImages=[];
  var modal=document.createElement('div');modal.className='composer-modal';
  modal.style.cssText='position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;padding:2rem';
  modal.innerHTML=`
    <div style="background:var(--bg-card);backdrop-filter:blur(20px);border-radius:24px;padding:2rem;width:100%;max-width:580px;box-shadow:0 32px 64px rgba(0,0,0,0.2);border:1px solid var(--border-subtle);max-height:90vh;overflow-y:auto">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem">
        <h3 style="font-family:Amiri,serif;font-size:1.3rem;margin:0;color:var(--text)">✨ منشور جديد</h3>
        <button onclick="var m=document.querySelector('.composer-modal');if(m){m.remove();uploadedImages=[]}" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text-muted);width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:var(--transition)">×</button>
      </div>
      <textarea id="composer-body" placeholder="شارك إنجاز، فكرة، أو فرصة... اكتب @@ لذكر شخص" style="width:100%;min-height:120px;padding:0.8rem 1rem;border-radius:14px;border:1.5px solid var(--border-subtle);font-family:inherit;font-size:0.92rem;resize:vertical;background:var(--bg);color:var(--text);line-height:1.8;transition:var(--transition)" onfocus="this.style.borderColor='var(--primary)'" onblur="this.style.borderColor='var(--border-subtle)'" oninput="handleMentionInput(this)"></textarea>

