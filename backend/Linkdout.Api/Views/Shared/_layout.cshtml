// ═══ RELATIVE TIME ═══
function relativeTime(dateStr){
  var d=new Date(dateStr),now=new Date(),diff=Math.floor((now-d)/1000);
  if(diff<60)return 'الآن';
  if(diff<3600)return 'منذ '+Math.floor(diff/60)+' دقيقة';
  if(diff<86400)return 'منذ '+Math.floor(diff/3600)+' ساعة';
  if(diff<604800)return 'منذ '+Math.floor(diff/86400)+' يوم';
  return d.toLocaleDateString('ar-EG');
}

// MENTIONS AUTOCOMPLETE
var mentionTimeout=null;
function handleMentionInput(textarea){
  clearTimeout(mentionTimeout);
  var dd=document.getElementById('mention-dropdown');
  if(dd)dd.remove();
  var cursorPos=textarea.selectionStart;
  var textBefore=textarea.value.substring(0,cursorPos);
  var atIndex=textBefore.lastIndexOf('@@');
  if(atIndex===-1)return;
  var afterAt=textBefore.substring(atIndex+1);
  if(afterAt.includes(' ')||afterAt.includes('\n'))return;
  mentionTimeout=setTimeout(function(){
    fetch('/api/users/mention-search?q='+encodeURIComponent(afterAt)).then(r=>r.json()).then(users=>{
      if(!users||users.length===0)return;
      var ddEl=document.createElement('div');ddEl.id='mention-dropdown';
      ddEl.style.cssText='position:absolute;z-index:9999;background:var(--bg-card);backdrop-filter:blur(20px);border:1px solid var(--border-subtle);border-radius:var(--radius);box-shadow:var(--shadow-xl);max-height:200px;overflow-y:auto;min-width:200px';
      users.forEach(function(u){
        var name=u.fullName||u.FullName||'?';
        var item=document.createElement('div');
        item.style.cssText='padding:0.5rem 0.8rem;cursor:pointer;font-size:0.82rem;color:var(--text);display:flex;align-items:center;gap:0.5rem;transition:var(--transition)';
        item.innerHTML='<span style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.75rem">'+(name[0]||'?')+'</span>'+name;
        item.onmouseover=function(){this.style.background='var(--bg)'};
        item.onmouseout=function(){this.style.background='transparent'};
        item.onclick=function(){
          var before=textarea.value.substring(0,atIndex);
          var after=textarea.value.substring(cursorPos);
          textarea.value=before+'@@'+name+' '+after;
          textarea.focus();textarea.setSelectionRange(before.length+name.length+2,before.length+name.length+2);
          ddEl.remove();
        };
        ddEl.appendChild(item);
      });
      textarea.parentNode.style.position='relative';
      textarea.parentNode.appendChild(ddEl);
    });
  },200);
}
