// IMGBB Upload handler
function handleImageUpload(files){
  if(!files||files.length===0)return;
  var maxFiles=3;
  if(uploadedImages.length+files.length>maxFiles){showToast('الحد الأقصى '+maxFiles+' صور');return}
  var status=document.getElementById('upload-status');
  var preview=document.getElementById('upload-preview');

  for(var i=0;i<Math.min(files.length,maxFiles-uploadedImages.length);i++){
    (function(file){
      uploadingCount++;
      status.style.display='block';status.textContent='⏳ جاري رفع '+file.name+'...';
      var formData=new FormData();
      formData.append('key','3cbedb6f7b32d9dc32ecd8f8e9131c7d');
      formData.append('image',file);
      formData.append('name',file.name);

      fetch('https://api.imgbb.com/1/upload',{method:'POST',body:formData})
      .then(r=>r.json()).then(d=>{
        if(d.success){
          uploadedImages.push(d.data.url);
          var imgEl=document.createElement('div');
          imgEl.style.cssText='position:relative;width:80px;height:80px;border-radius:10px;overflow:hidden;border:2px solid var(--border-subtle)';
          imgEl.innerHTML='<img src="'+d.data.thumb.url+'" style="width:100%;height:100%;object-fit:cover"><button onclick="this.parentElement.remove();var idx=uploadedImages.indexOf(\''+d.data.url+'\');if(idx>-1)uploadedImages.splice(idx,1)" style="position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:20px;height:20px;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center">&times;</button>';
          preview.appendChild(imgEl);
          status.textContent='✅ '+uploadedImages.length+' صورة مرفوعة';
        }else{showToast('فشل رفع '+file.name)}
      }).catch(function(){showToast('خطأ في رفع '+file.name)})
      .finally(function(){uploadingCount--;if(uploadingCount===0&&uploadedImages.length===0)status.style.display='none'});
    })(files[i]);
  }
  document.getElementById('imageUpload').value='';
}

